# MotionLint picks the first available provider in this order:
#   ollama (local) → anthropic → openai → google
# Set whichever ones you have. Real env vars take precedence over .env values.

# --- Cloud vision LLMs ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Local Ollama (optional) ---
# OLLAMA_HOST=http://localhost:11434

# --- Override env file resolution (optional) ---
# MOTIONLINT_ENV_FILE=/absolute/path/to/motionlint.env
