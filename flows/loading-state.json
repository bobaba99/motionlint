{
  "$schema": "https://motionlint.dev/flow-schema.json",
  "name": "loading-state-feedback",
  "url": "http://localhost:4173/loading",
  "viewport": { "name": "desktop", "width": 1440, "height": 900 },
  "expected_animations": [
    "skeleton shimmer animates continuously on placeholder cards",
    "skeleton cards cross-fade to real content after ~1.4s",
    "no flash of unstyled content (FOUC) during the swap"
  ],
  "steps": [
    { "do": "capture", "label": "skeleton state at t=0", "burst_ms": 1000, "frames": 5 },
    { "do": "wait", "ms": 600 },
    { "do": "capture", "label": "mid-shimmer (~600ms)", "burst_ms": 600, "frames": 4 },
    { "do": "wait", "ms": 1200 },
    { "do": "capture", "label": "after content swap (~1.8s)", "burst_ms": 800, "frames": 4 }
  ]
}
